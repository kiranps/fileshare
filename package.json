{
    "name": "webdav-server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "mobile:start": "pnpm --filter mobile start",
        "mobile:android": "pnpm --filter mobile android",
        "mobile:android:release": "pnpm --filter mobile android:release",
        "rust:build": "pnpm --filter react-native-webdav-server ubrn:android && pnpm install",
        "rust:clean": "pnpm --filter react-native-webdav-server ubrn:clean",
        "rust:test": "cd packages/react-native-webdav-server/rust/webdavserver; cargo test",
        "rust:server": "cd packages/react-native-webdav-server/rust/webdavserver; cargo run --example start_server",
        "android": "expo run:android",
        "ios": "expo run:ios"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.27.0",
    "devDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "expo": "~54.0.33",
        "react": "19.1.0",
        "react-native": "0.81.5"
    }
}
