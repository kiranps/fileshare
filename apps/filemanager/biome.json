{
	"$schema": "https://json.schemastore.org/biome",
	"root": true,
	"files": {
		"includes": ["src/**/*.{ts,tsx,js,jsx}", "*.{app.json,ts,js,json}", "!!**/dist", "!!**/node_modules"]
	},
	"formatter": {
		"lineWidth": 120
	},
	"linter": {
		"enabled": true
	},
	"javascript": {
		"jsxRuntime": "reactClassic"
	}
}
